7,"length":32},{"start":1347,"length":32}]}},"methodIdentifiers":{"ONE()":"c2ee3a08","agreementRateBps(address)":"6e8827ee","alphaBps()":"c87e38fe","governor()":"0c340a24","knownAt(uint256)":"6c8b7472","knownCount()":"1d4e5f4d","processed(uint256)":"05a79e06","recordSettled(uint256)":"5771c410","repOf(address)":"e351a110","weightOf(address)":"dd4bc101"},"rawMetadata":"{\"compiler\":{\"version\":\"0.8.31+commit.fd3a2265\"},\"language\":\"Solidity\",\"output\":{\"abi\":[{\"inputs\":[{\"internalType\":\"contract IAIGovernor\",\"name\":\"governor_\",\"type\":\"address\"},{\"internalType\":\"uint32\",\"name\":\"alphaBps_\",\"type\":\"uint32\"}],\"stateMutability\":\"nonpayable\",\"type\":\"constructor\"},{\"inputs\":[{\"internalType\":\"uint256\",\"name\":\"taskId\",\"type\":\"uint256\"}],\"name\":\"AlreadyProcessed\",\"type\":\"error\"},{\"inputs\":[{\"internalType\":\"uint256\",\"name\":\"taskId\",\"type\":\"uint256\"}],\"name\":\"NotSettled\",\"type\":\"error\"},{\"anonymous\":false,\"inputs\":[{\"indexed\":true,\"internalType\":\"address\",\"name\":\"operator\",\"type\":\"address\"},{\"indexed\":true,\"internalType\":\"uint256\",\"name\":\"taskId\",\"type\":\"uint256\"},{\"indexed\":false,\"internalType\":\"bool\",\"name\":\"agreed\",\"type\":\"bool\"},{\"indexed\":false,\"internalType\":\"uint32\",\"name\":\"weightBps\",\"type\":\"uint32\"}],\"name\":\"ReputationUpdated\",\"type\":\"event\"},{\"anonymous\":false,\"inputs\":[{\"indexed\":true,\"internalType\":\"uint256\",\"name\":\"taskId\",\"type\":\"uint256\"},{\"indexed\":false,\"internalType\":\"uint8\",\"name\":\"revealed\",\"type\":\"uint8\"},{\"indexed\":false,\"internalType\":\"uint8\",\"name\":\"agreed\",\"type\":\"uint8\"}],\"name\":\"ThoughtScored\",\"type\":\"event\"},{\"inputs\":[],\"name\":\"ONE\",\"outputs\":[{\"internalType\":\"uint32\",\"name\":\"\",\"type\":\"uint32\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"address\",\"name\":\"operator\",\"type\":\"address\"}],\"name\":\"agreementRateBps\",\"outputs\":[{\"internalType\":\"uint32\",\"name\":\"\",\"type\":\"uint32\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[],\"name\":\"alphaBps\",\"outputs\":[{\"internalType\":\"uint32\",\"name\":\"\",\"type\":\"uint32\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[],\"name\":\"governor\",\"outputs\":[{\"internalType\":\"contract IAIGovernor\",\"name\":\"\",\"type\":\"address\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"uint256\",\"name\":\"index\",\"type\":\"uint256\"}],\"name\":\"knownAt\",\"outputs\":[{\"internalType\":\"address\",\"name\":\"\",\"type\":\"address\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[],\"name\":\"knownCount\",\"outputs\":[{\"internalType\":\"uint256\",\"name\":\"\",\"type\":\"uint256\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"uint256\",\"name\":\"\",\"type\":\"uint256\"}],\"name\":\"processed\",\"outputs\":[{\"internalType\":\"bool\",\"name\":\"\",\"type\":\"bool\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"uint256\",\"name\":\"taskId\",\"type\":\"uint256\"}],\"name\":\"recordSettled\",\"outputs\":[],\"stateMutability\":\"nonpayable\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"address\",\"name\":\"operator\",\"type\":\"address\"}],\"name\":\"repOf\",\"outputs\":[{\"components\":[{\"internalType\":\"uint32\",\"name\":\"weightBps\",\"type\":\"uint32\"},{\"internalType\":\"uint32\",\"name\":\"participated\",\"type\":\"uint32\"},{\"internalType\":\"uint32\",\"name\":\"agreed\",\"type\":\"uint32\"},{\"internalType\":\"uint64\",\"name\":\"lastTaskId1\",\"type\":\"uint64\"},{\"internalType\":\"uint64\",\"name\":\"lastUpdated\",\"type\":\"uint64\"}],\"internalType\":\"struct AIReputation.Rep\",\"name\":\"\",\"type\":\"tuple\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"address\",\"name\":\"operator\",\"type\":\"address\"}],\"name\":\"weightOf\",\"outputs\":[{\"internalType\":\"uint32\",\"name\":\"\",\"type\":\"uint32\"}],\"stateMutability\":\"view\",\"type\":\"function\"}],\"devdoc\":{\"author\":\"Hanzo AI Inc / Lux Network\",\"details\":\"Orthogonal by design (Rich Hickey): holds its own ledger, only READS the governor's committed settled state (`getThought`, `getVerdicts`) and WRITES reputation; it never touches the governor and changes no consensus outcome. Permissionless + idempotent: anyone may call `recordSettled(taskId)` once a thought is settled; each task is counted exactly once. Dissent is information (constitutional Rule 9): divergence decays weight gently via the EMA \\u2014 it is not a punishment event, and an honest minority that is later vindicated recovers as subsequent thoughts settle its way. Withholding (committed, never revealed) is out of scope here \\u2014 it is the one fault left to the optional bonded backstop.\",\"kind\":\"dev\",\"methods\":{},\"title\":\"AIReputation\",\"version\":1},\"userdoc\":{\"kind\":\"user\",\"methods\":{\"ONE()\":{\"notice\":\"Full weight in basis points.\"},\"agreementRateBps(address)\":{\"notice\":\"Lifetime agreement rate (bps) \\u2014 `agreed/participated`, 0 if never seen.\"},\"alphaBps()\":{\"notice\":\"EMA responsiveness in bps (e.g. 2000 = 0.2): higher reacts faster to recent behavior, lower is steadier/longer-memory.\"},\"knownAt(uint256)\":{\"notice\":\"The validator address at `index` (measurement order), for enumeration.\"},\"knownCount()\":{\"notice\":\"Number of validators ever measured.\"},\"recordSettled(uint256)\":{\"notice\":\"Fold the settled decision of `taskId` into every revealing validator's reputation. Reverts if not settled or already processed.\"},\"repOf(address)\":{\"notice\":\"A validator's full reputation record.\"},\"weightOf(address)\":{\"notice\":\"A validator's current Proof-of-AI weight (bps, 0..10000).\"}},\"notice\":\"Proof-of-AI reputation for thinking-validators \\u2014 the on-chain, continuous signal that replaces slashing-as-primary (Thinking Chains \\u00a77, \\\"Proof-of-AI: The AI Bitcoin\\\"). A validator earns standing by AGREEING with the settled canonical decision over time, and loses it by diverging. Bad actors are routed around (their weight decays toward zero), not slashed \\u2014 the Bittensor lesson: pay for measured, ongoing answer quality rather than threaten to burn capital, so heterogeneous/permissionless providers can participate. `weightBps` is an exponential moving average (EMA) of per-thought agreement, in basis points [0, 10000]:   agreed  this thought:  w <- w + alpha*(10000 - w)/10000   (rises toward 10000)   diverged this thought: w <- w - alpha*w/10000             (decays toward 0) where `alphaBps` sets responsiveness. New validators start at 0 and earn weight by being right alongside the quorum (Yuma-style), so reputation must be earned, never granted. \\\"Agreement\\\" = the validator's revealed (vote, confidenceBucket) equals the thought's settled canonical pair \\u2014 the same consensus key the governor tallied.\",\"version\":1}},\"settings\":{\"compilationTarget\":{\"contracts/ai/governance/AIReputation.sol\":\"AIReputation\"},\"evmVersion\":\"cancun\",\"libraries\":{},\"metadata\":{\"bytecodeHash\":\"ipfs\"},\"optimizer\":{\"enabled\":true,\"runs\":200},\"remappings\":[\":\\\"ds-test/=lib/alchemix-v2/\\\"../lib/ds-test/src/\",\":\\\"forge-std/=lib/alchemix-v2/\\\"lib/forge-std/src/\",\":@account-abstraction/=lib/account-abstraction/contracts/\",\":@balancer-labs/=lib/balancer/../../node_modules/@balancer-labs/\",\":@balancer/=lib/balancer/pkg/\",\":@chainlink/contracts/=lib/chainlink/contracts/\",\":@comet-contracts/=lib/compound-v3/contracts/\",\":@compound-v3/=lib/compound-v3/contracts/\",\":@curve/=lib/curve/contracts/\",\":@forge-std/=lib/compound-v3/forge/lib/forge-std/\",\":@gnosis.pm/safe-contracts/=lib/safe-smart-account/contracts/\",\":@lido/=lib/li